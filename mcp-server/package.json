{
  "name": "@tim0-12432/hotkeyless-ahk-mcp-server",
  "version": "1.0.0",
  "mcpName": "io.github.tim0-12432/HotkeylessAHK-mcp-skill",
  "private": true,
  "description": "MCP server for Hotkeyless AHK HTTP API.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsgo -p tsconfig.json",
    "build": "vite build",
    "clean": "node -e \"import('node:fs').then((fs) => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "start": "node dist/index.js",
    "test": "vitest run",
    "publish:mcp": "../mcp-publisher.exe publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "^7.0.0-dev.20260406.1",
    "vite": "^8.0.5",
    "vitest": "^3.2.4"
  }
}
